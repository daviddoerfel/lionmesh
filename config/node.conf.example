# LionMesh Node Configuration
# Copy to node.conf and edit before first run.

[node]
node_id   = lionmesh-a
node_name = GHOST-ALPHA
mesh_ip   = 10.41.0.1
mesh_network = 10.41.0.0/16

# ─── Radio mode ───────────────────────────────────────────────────────────────
# wifi     : Standard WiFi (batman-adv over 802.11s via Alfa adapter)
#            No LimeSDR required. Data plane = standard 802.11.
# lionmesh: LionMesh OFDM PHY via LimeSDR (recommended for long range).
#            Replaces the Alfa adapter. Requires SoapySDR + LimeSDR hardware.
[radio]
mode         = wifi
device_args  = driver=lime
freq_hz      = 2400000000         # 2400 MHz (recommended) or 863000000 (authorised deployments only)
bandwidth_hz = 5000000            # 5 MHz → best range (+6 dB vs 20 MHz)
mcs          = 4                  # 16-QAM 3/4 → 9 Mbps @ 5 MHz, good for 720p H.265
tx_gain_db   = 50.0
rx_gain_db   = 40.0

# ─── WiFi (used when mode = wifi) ────────────────────────────────────────────
[wifi]
wifi_interface = wlan0
mesh_ssid      = LIONMESH-MESH
mesh_channel_2g = 6
mesh_channel_5g  = 36
band_switch_threshold_down = -70
band_switch_threshold_up   = -60

# ─── LoRa control plane (always active, regardless of radio mode) ─────────────
[lora]
lora_port    = /dev/ttyAMA0
lora_channel = LIONMESH

# ─── GPS ──────────────────────────────────────────────────────────────────────
[gps]
gpsd_host             = localhost
gpsd_port             = 2947
gps_broadcast_interval = 30

# ─── Video (LionMesh mode only) ──────────────────────────────────────────────
[video]
enabled      = true
width        = 1280
height       = 720
fps          = 25
bitrate_kbps = 6000
source       = v4l2
device       = /dev/video0

# ─── API / WebApp ─────────────────────────────────────────────────────────────
[api]
api_port       = 8080
admin_password = changeme
